/ {
    chosen {
        zmk,kscan = <&kscan0>;
        zmk,physical-layouts = &atreyu_rev2_layout;
    };
}; 
&atreyu_rev2_layout {
	transform = <&default_transform>;
	kscan = <&kscan0>;
};

zephyr_udc0: &usbd { 
    compatible = "nordic,nrf-usbd"; 
    status = "okay"; 
};
