#include <physical_layouts.dtsi>


/ {
    atreyu_rev2_layout: atreyu_rev2_layout {
        compatible = "zmk,physical-layout";
        display-name = "atreyu_rev2 Keyboard Layout";
        kscan = <&kscan0>;
        transform = <&default_transform>;
        keys  //                     w   h    x    y     rot    rx    ry
            = <&key_physical_attrs 100 100  100   75     800   100    75>
            , <&key_physical_attrs 100 100  200   50     800   200    50>
            , <&key_physical_attrs 100 100  300   25     800   300    25>
            , <&key_physical_attrs 100 100  400    0     800   400     0>
            , <&key_physical_attrs 100 100  500   25     800   500    25>
            , <&key_physical_attrs 100 100  600   50     800   600    50>
            , <&key_physical_attrs 100 100  875  265  (-800)   875   265>
            , <&key_physical_attrs 100 100  975  240  (-800)   975   240>
            , <&key_physical_attrs 100 100 1075  215  (-800)  1075   215>
            , <&key_physical_attrs 100 100 1175  240  (-800)  1175   240>
            , <&key_physical_attrs 100 100 1275  265  (-800)  1275   265>
            , <&key_physical_attrs 100 100 1375  290  (-800)  1375   290>
            , <&key_physical_attrs 100 100  100  175     800   100   175>
            , <&key_physical_attrs 100 100  200  150     800   200   150>
            , <&key_physical_attrs 100 100  300  125     800   300   125>
            , <&key_physical_attrs 100 100  400  100     800   400   100>
            , <&key_physical_attrs 100 100  500  125     800   500   125>
            , <&key_physical_attrs 100 100  600  150     800   600   150>
            , <&key_physical_attrs 100 100  875  365  (-800)   875   365>
            , <&key_physical_attrs 100 100  975  340  (-800)   975   340>
            , <&key_physical_attrs 100 100 1075  315  (-800)  1075   315>
            , <&key_physical_attrs 100 100 1175  340  (-800)  1175   340>
            , <&key_physical_attrs 100 100 1275  365  (-800)  1275   365>
            , <&key_physical_attrs 100 100 1375  390  (-800)  1375   390>
            , <&key_physical_attrs 100 100  100  275     800   100   275>
            , <&key_physical_attrs 100 100  200  250     800   200   250>
            , <&key_physical_attrs 100 100  300  225     800   300   225>
            , <&key_physical_attrs 100 100  400  200     800   400   200>
            , <&key_physical_attrs 100 100  500  225     800   500   225>
            , <&key_physical_attrs 100 100  600  250     800   600   250>
            , <&key_physical_attrs 100 100  875  465  (-800)   875   465>
            , <&key_physical_attrs 100 100  975  440  (-800)   975   440>
            , <&key_physical_attrs 100 100 1075  415  (-800)  1075   415>
            , <&key_physical_attrs 100 100 1175  440  (-800)  1175   440>
            , <&key_physical_attrs 100 100 1275  465  (-800)  1275   465>
            , <&key_physical_attrs 100 100 1375  490  (-800)  1375   490>
            , <&key_physical_attrs 100 100  100  375     800   100   375>
            , <&key_physical_attrs 100 100  200  350     800   200   350>
            , <&key_physical_attrs 100 100  300  325     800   300   325>
            , <&key_physical_attrs 100 100  400  300     800   400   300>
            , <&key_physical_attrs 100 100  500  325     800   500   325>
            , <&key_physical_attrs 100 100  600  350     800   600   350>
            , <&key_physical_attrs 100 100  875  565  (-800)   875   565>
            , <&key_physical_attrs 100 100  975  540  (-800)   975   540>
            , <&key_physical_attrs 100 100 1075  515  (-800)  1075   515>
            , <&key_physical_attrs 100 100 1175  540  (-800)  1175   540>
            , <&key_physical_attrs 100 100 1275  565  (-800)  1275   565>
            , <&key_physical_attrs 100 100 1375  590  (-800)  1375   590>
            , <&key_physical_attrs 100 100  100  500     800   100   500>
            , <&key_physical_attrs 100 100  250  530       0   250   530>
            , <&key_physical_attrs 100 100  450  475     800   450   475>
            , <&key_physical_attrs 100 100  625  400    1500   625   400>
            , <&key_physical_attrs 100 100  810  270    2500   810   270>
            , <&key_physical_attrs 100 100  710  295     800   710   295>
            , <&key_physical_attrs 100 100  750  515  (-800)   750   515>
            , <&key_physical_attrs 100 100  525  940 (-2500)   525   940>
            , <&key_physical_attrs 100 100  810  815 (-1500)   810   815>
            , <&key_physical_attrs 100 100 1025  700  (-800)  1025   700>
